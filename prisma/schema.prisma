generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model LoyaltyTier {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique
  icon        String
  condition   String
  sortOrder   Int
  benefits    LoyaltyBenefit[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model LoyaltyBenefit {
  id          String      @id @default(cuid())
  label       String
  value       String
  sortOrder   Int
  tierId      String
  tier        LoyaltyTier @relation(fields: [tierId], references: [id], onDelete: Cascade)
}

model LoyaltyConfig {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model Product {
  id              String   @id
  title           String
  englishName     String?
  category        String
  flag            String?
  image           String
  price           Int
  originalPrice   Int?
  rating          Float    @default(4.9)
  reviewsCount    Int      @default(0)
  description     String
  fullDescription String?
  ingredients     String?
  certifications  String?
  usage           String?
  volume          String?
  gift            String?
  tagline         String?
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

