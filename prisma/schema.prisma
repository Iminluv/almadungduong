generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model LoyaltyTier {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique
  icon        String
  condition   String
  sortOrder   Int
  benefits    LoyaltyBenefit[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model LoyaltyBenefit {
  id          String      @id @default(cuid())
  label       String
  value       String
  sortOrder   Int
  tierId      String
  tier        LoyaltyTier @relation(fields: [tierId], references: [id], onDelete: Cascade)
}

model LoyaltyConfig {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
